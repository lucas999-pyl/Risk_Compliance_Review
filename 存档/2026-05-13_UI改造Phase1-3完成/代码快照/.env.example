APP_NAME=化工合规 RAG 工具
DATABASE_PATH=data/risk-review.db
STORAGE_DIR=data/objects

# ====================================================================
# 双平台 OpenAI-兼容 v1 凭证（embed 与 LLM 各一套，互不影响）
# 如只想用同一平台，下面 4 个字段填同样的 base_url + api_key 即可，
# 或继续使用旧的 OPENAI_API_BASE + OPENAI_API_KEY（自动回填给两边）。
# ====================================================================

# Embedding 平台：UniAPI 转发 Qwen text-embedding-v4（OpenAI 兼容 v1）
CHEM_RAG_EMBEDDING_BASE_URL=https://api.uniapi.io/v1
CHEM_RAG_EMBEDDING_API_KEY=<填 UniAPI 平台 API Key>
CHEM_RAG_EMBEDDING_PROVIDER=openai_compatible
CHEM_RAG_EMBEDDING_MODEL=text-embedding-v4
CHEM_RAG_EMBEDDING_DIMENSIONS=1024

# LLM 平台：DeepSeek 官方（OpenAI 兼容 v1，V4 系列 2026-04-24 发布）
CHEM_RAG_LLM_BASE_URL=https://api.deepseek.com/v1
CHEM_RAG_LLM_API_KEY=<填 DeepSeek 官方 API Key>
CHEM_RAG_LLM_PROVIDER=openai_compatible
CHEM_RAG_LLM_MODEL=deepseek-v4-flash

# 共享配置
CHEM_RAG_VECTOR_STORE_DIR=data/vector_store/chemical_rag
CHEM_RAG_REQUEST_TIMEOUT_SECONDS=30
RCR_ENABLE_LLM=true
